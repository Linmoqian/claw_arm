{
  "skill_name": "vision-detection",
  "description": "SO100机械臂视觉检测定位技能 - 使用摄像头和深度学习模型识别物体,计算精确位置,为机械臂抓取提供多格式坐标数据",
  "evals": [
    {
      "id": 1,
      "name": "检测杯子并输出多格式坐标",
      "prompt": "使用摄像头检测桌子上的杯子,输出它的像素坐标、3D坐标和极坐标",
      "expected_output": "检测器应成功识别杯子,并输出三种格式的坐标数据:\n1. 像素坐标: (x, y) 例如 (320, 240)\n2. 3D坐标: (x, y, z) 例如 (200.5, 50.3, 100.0) mm\n3. 极坐标: (角度, 距离) 例如 (0.0°, 250.7px)\n每个结果应包含类别名和置信度",
      "files": [],
      "assertions": [
        {
          "name": "成功检测到杯子",
          "check": "output_contains_cup_detection",
          "expected": true
        },
        {
          "name": "输出包含像素坐标",
          "check": "output_has_pixel_coordinates",
          "expected": true
        },
        {
          "name": "输出包含3D坐标",
          "check": "output_has_3d_coordinates",
          "expected": true
        },
        {
          "name": "输出包含极坐标",
          "check": "output_has_polar_coordinates",
          "expected": true
        }
      ]
    },
    {
      "id": 2,
      "name": "检测多个物体并按距离排序",
      "prompt": "检测摄像头画面中的所有瓶子,按距离从近到远排序,列出每个瓶子的位置和置信度",
      "expected_output": "检测器应识别所有瓶子,按极坐标距离从近到远排序输出。每个瓶子应包含:\n- 类别: bottle\n- 置信度: 例如 0.89\n- 像素坐标: (x, y)\n- 极坐标距离: 用于排序\n输出应按距离升序排列",
      "files": [],
      "assertions": [
        {
          "name": "检测到至少一个瓶子",
          "check": "detected_at_least_one_bottle",
          "expected": true
        },
        {
          "name": "结果按距离排序",
          "check": "results_sorted_by_distance",
          "expected": true
        },
        {
          "name": "包含置信度信息",
          "check": "includes_confidence_scores",
          "expected": true
        }
      ]
    },
    {
      "id": 3,
      "name": "颜色检测模式",
      "prompt": "使用颜色检测模式识别红色物体,输出它们的像素坐标和相对于图像中心的角度",
      "expected_output": "检测器应使用颜色检测模式(HSV),识别所有红色区域。\n每个物体应包含:\n- 像素坐标: (x, y)\n- 极坐标角度: 相对于图像中心的角度(度)\n- 边界框面积\n结果应按面积从大到小排序",
      "files": [],
      "assertions": [
        {
          "name": "使用颜色检测模式",
          "check": "uses_color_detector",
          "expected": true
        },
        {
          "name": "识别到红色物体",
          "check": "detected_red_objects",
          "expected": true
        },
        {
          "name": "输出包含角度信息",
          "check": "output_includes_angles",
          "expected": true
        }
      ]
    },
    {
      "id": 4,
      "name": "手眼标定流程",
      "prompt": "执行手眼标定流程,采集10个姿态的标定数据,计算相机内参和手眼标定矩阵",
      "expected_output": "标定器应:\n1. 连接机械臂和摄像头\n2. 引导用户采集标定点\n3. 计算相机内参矩阵\n4. 计算手眼标定矩阵\n5. 计算重投影误差\n6. 保存标定数据到JSON文件\n最终应输出标定数据文件和重投影误差(应<5像素)",
      "files": [],
      "assertions": [
        {
          "name": "成功采集标定点",
          "check": "captured_calibration_points",
          "expected": true
        },
        {
          "name": "计算相机内参",
          "check": "calculated_camera_intrinsics",
          "expected": true
        },
        {
          "name": "计算手眼矩阵",
          "check": "calculated_hand_eye_matrix",
          "expected": true
        },
        {
          "name": "保存标定数据",
          "check": "saved_calibration_file",
          "expected": true
        }
      ]
    },
    {
      "id": 5,
      "name": "实时目标追踪",
      "prompt": "追踪摄像头画面中的人,持续30秒,实时输出他们的位置变化",
      "expected_output": "检测器应启动实时追踪模式:\n1. 以约30fps检测人物\n2. 实时输出像素坐标变化\n3. 计算移动速度(px/frame)\n4. 如果目标丢失超过阈值,应报告并尝试重新检测\n5. 支持按'q'键提前退出\n应输出追踪过程中的位置和速度数据",
      "files": [],
      "assertions": [
        {
          "name": "启动追踪模式",
          "check": "tracking_mode_active",
          "expected": true
        },
        {
          "name": "实时输出位置",
          "check": "outputs_realtime_position",
          "expected": true
        },
        {
          "name": "计算移动速度",
          "check": "calculates_velocity",
          "expected": true
        }
      ]
    }
  ]
}
